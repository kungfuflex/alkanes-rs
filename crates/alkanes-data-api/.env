# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/alkanes

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Sandshrew RPC Configuration (unified Bitcoin + Metashrew endpoint)
SANDSHREW_URL=http://localhost:8080

# Network Configuration (mainnet, testnet, signet, regtest)
NETWORK_ENV=mainnet

# Alkane Factory ID (block:tx format)
ALKANE_FACTORY_ID=840000:1

# Server Configuration
HOST=0.0.0.0
PORT=3000

# Ethereum RPC for BTC price feed (Uniswap V3 on Ethereum mainnet)
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Logging
RUST_LOG=info,alkanes_data_api=debug
