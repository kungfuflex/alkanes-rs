# Copy this file to .env and adjust values for your environment.

# Postgres connection URL (required)
DATABASE_URL=postgres://user:pass@localhost:5432/alkanes_indexer

# Metashrew/Sandshrew JSON-RPC endpoint
# Default: http://localhost:18888
SANDSHREW_RPC_URL=http://localhost:18888

# Optional: Bitcoin Core JSON-RPC endpoint (if different from Sandshrew)
#BITCOIN_RPC_URL=http://user:pass@127.0.0.1:8332

# Optional: Esplora HTTP base URL (if applicable)
#ESPLORA_URL=http://localhost:3002

# Network identity used by provider constructor
# Default: regtest (other values: mainnet, testnet, signet)
NETWORK=regtest
# Optional override for notifier key naming (defaults to NETWORK or 'mainnet')
#NETWORK_ENV=regtest

# Poll interval for Metashrew height in milliseconds
# Default: 2000
POLL_INTERVAL_MS=2000

# Optional: start height for historical catch-up
# When set, the coordinator will process sequentially from this height (or from
# the last persisted progress) up to the current tip.
#START_HEIGHT=800000

# Required: Factory contract ID for AMM pools discovery (numeric lo parts)
FACTORY_BLOCK_ID=0
FACTORY_TX_ID=0

# ---- RPC resiliency tuning (sensible defaults shown) ----
# Global in-process concurrency cap for outbound RPCs
RPC_MAX_CONCURRENCY=64

# Max retry attempts per RPC
RPC_MAX_RETRIES=5

# Exponential backoff base and cap (milliseconds)
RPC_BASE_BACKOFF_MS=200
RPC_MAX_BACKOFF_MS=5000

# Per-call timeout (milliseconds)
RPC_TIMEOUT_MS=20000

# Circuit breaker cooldown before half-open probe (milliseconds)
RPC_CIRCUIT_COOLDOWN_MS=5000

# Logging (example)
#RUST_LOG=info

# Redis URL for notifier (optional; defaults to redis://127.0.0.1/)
#REDIS_URL=redis://localhost:6379/

